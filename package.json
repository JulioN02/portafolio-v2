  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.11",
      "postcss": ">=8.5.10",
      "qs": ">=6.15.2"
    }
  }
}