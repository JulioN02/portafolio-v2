# Environment variables for J Soft Solutions Portafolio API

# Database (Supabase PostgreSQL)
# Get from: Supabase Dashboard → Project Settings → Database → Connection String
DATABASE_URL="postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres"

# JWT Authentication
JWT_SECRET="jsoft-portafolio-secret-key-2026-minimum-32-chars"
JWT_EXPIRES_IN="7d"

# Supabase Storage (image uploads)
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_SERVICE_KEY="sb_secret_your_service_key"
SUPABASE_BUCKET="portafolio-v2-images"

# Server
NODE_ENV="development"
PORT=3000

# CORS (comma separated origins in production)
CORS_ORIGIN="http://localhost:5173,http://localhost:4173,http://localhost:5175"
