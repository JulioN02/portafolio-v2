# Environment variables for J Soft Solutions Portafolio API

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/portafolio_v2"

# JWT Authentication
JWT_SECRET="jsoft-portafolio-secret-key-2026-minimum-32-chars"
JWT_EXPIRES_IN="7d"

# Cloudinary (for production - optional in development)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Server
NODE_ENV="development"
PORT=3000

# CORS (comma separated origins in production)
CORS_ORIGIN="http://localhost:5173,http://localhost:4173"