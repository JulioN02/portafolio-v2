{
  "version": 2,
  "builds": [
    {
      "src": "api/src/index.ts",
      "use": "@vercel/node",
      "config": {
        "esbuild": {
          "external": ["@prisma/client", "@prisma/client/*"]
        }
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "api/src/index.ts" }
  ]
}
